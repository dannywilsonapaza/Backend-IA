{
  "name": "ai-suggestions-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:fc": "set AI_MODE=fc&& tsx watch src/index.ts",
    "dev:5066": "set PORT=5066&& tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "compression": "^1.7.4",
