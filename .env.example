OPENAI_API_KEY=
PORT=5066
PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=8000

# Backend principal (cotizacionesmigracion-backend-node)
BACKEND_PRINCIPAL_URL=http://localhost:3920
BACKEND_PRINCIPAL_TIMEOUT=10000

# n8n (webhook del asistente). Si no se configura, /api/chat usa fallbackOutput.
N8N_WEBHOOK_URL=
N8N_TIMEOUT=15000

UPSTREAM_BASE_URL=http://localhost:3920/api/cotizar/
# Si el upstream requiere autenticación y no deseas reenviar el Authorization del frontend,
# coloca aquí un token fijo (sin el prefijo Bearer). Ejemplo: abc.def.ghi
# El servidor lo enviará como: Authorization: Bearer <UPSTREAM_TOKEN>
UPSTREAM_TOKEN=
